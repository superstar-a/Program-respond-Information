@model IEnumerable<QLTTYKPH.Models.Feedback>
@{
    ViewData["Title"] = "Phản hồi của tôi";
}
<h5 class="fw-bold mb-3"><i class="bi bi-clock-history me-2 text-primary"></i>Phản hồi của tôi</h5>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            Bạn chưa gửi phản hồi nào.
            <div class="mt-3">
                <a asp-action="OpenSurveys" class="btn btn-primary btn-sm">Xem khảo sát đang mở</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Khảo sát</th>
                        <th>Thời gian gửi</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @{int stt = 1;}
                    @foreach (var f in Model)
                    {
                        <tr>
                            <td class="text-muted small">@stt++</td>
                            <td class="fw-semibold">@f.Survey?.Title</td>
                            <td class="small text-muted">@f.SubmittedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @switch (f.Status)
                                {
                                    case QLTTYKPH.Models.FeedbackStatus.New:
                                        <span class="badge bg-secondary">Đã gửi</span>
                                        break;
                                    case QLTTYKPH.Models.FeedbackStatus.Processing:
                                        <span class="badge bg-warning text-dark">Đang xử lý</span>
                                        break;
                                    case QLTTYKPH.Models.FeedbackStatus.Completed:
                                        <span class="badge bg-success">Đã hoàn thành</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="ViewMyFeedback" asp-route-id="@f.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
