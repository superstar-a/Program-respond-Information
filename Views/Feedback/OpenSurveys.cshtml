@model IEnumerable<QLTTYKPH.Models.Survey>
@{
    ViewData["Title"] = "Khảo sát đang mở";
    var submittedIds = ViewBag.SubmittedIds as List<int> ?? new List<int>();
}
<h5 class="fw-bold mb-3"><i class="bi bi-clipboard-check me-2 text-primary"></i>Khảo sát đang mở</h5>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            Hiện chưa có khảo sát nào dành cho bạn.
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var s in Model)
        {
            bool done = submittedIds.Contains(s.Id);
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 @(done ? "border-success" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title fw-bold mb-0">@s.Title</h6>
                            @if (done)
                            {
                                <span class="badge bg-success ms-2 flex-shrink-0"><i class="bi bi-check-circle me-1"></i>Đã nộp</span>
                            }
                            else
                            {
                                <span class="badge bg-primary ms-2 flex-shrink-0"><i class="bi bi-clock me-1"></i>Chưa làm</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <p class="card-text text-muted small mb-2">@s.Description</p>
                        }
                        <div class="mb-3">
                            @if (s.Category != null)
                            {
                                <span class="badge bg-info text-dark me-1">@s.Category.Name</span>
                            }
                            @if (s.Department != null)
                            {
                                <span class="badge bg-light text-dark border">@s.Department.Name</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        @if (done)
                        {
                            <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Bạn đã hoàn thành khảo sát này</span>
                        }
                        else
                        {
                            <a asp-action="TakeSurvey" asp-route-surveyId="@s.Id" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-pencil-square me-1"></i>Tham gia khảo sát
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
