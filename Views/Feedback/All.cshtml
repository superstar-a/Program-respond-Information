@model IEnumerable<QLTTYKPH.ViewModels.FeedbackSurveyListViewModel>
@{
    ViewData["Title"] = "Tổng quan Phản hồi";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-chat-left-text me-2 text-primary"></i>Danh sách Khảo sát cần xử lý</h5>
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-5">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm tên khảo sát..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Tìm kiếm</button>
                <a asp-action="All" class="btn btn-outline-secondary ms-1">Xóa lọc</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3">
    @foreach (var s in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title text-truncate" title="@s.Title">@s.Title</h5>
                    <div class="mb-2">
                        @if (!s.IsPublished)
                        {
                            <span class="badge bg-secondary">Bản nháp</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Đã xuất bản</span>
                        }
                    </div>
                    <ul class="list-unstyled small text-muted mb-3">
                        <li><i class="bi bi-tag me-1"></i> Danh mục: @(s.CategoryName ?? "-")</li>
                        <li><i class="bi bi-building me-1"></i> Phòng ban: @(s.DepartmentName ?? "Tất cả")</li>
                        <li><i class="bi bi-mortarboard me-1"></i> Lớp: @(s.ClassName ?? "Tất cả")</li>
                    </ul>
                    <hr />
                    <div class="d-flex justify-content-between text-center mb-3">
                        <div>
                            <div class="fs-4 text-primary fw-bold">@s.TotalFeedbacks</div>
                            <div class="small text-muted">Tổng số</div>
                        </div>
                        <div>
                            <div class="fs-4 text-danger fw-bold">@s.NewFeedbacks</div>
                            <div class="small text-muted">Mới</div>
                        </div>
                        <div>
                            <div class="fs-4 text-warning fw-bold">@s.ProcessingFeedbacks</div>
                            <div class="small text-muted">Đang XL</div>
                        </div>
                        <div>
                            <div class="fs-4 text-success fw-bold">@s.CompletedFeedbacks</div>
                            <div class="small text-muted">Xong</div>
                        </div>
                    </div>
                    <a asp-action="BySurvey" asp-route-surveyId="@s.SurveyId" class="btn btn-outline-primary w-100">
                        <i class="bi bi-list-check me-1"></i> Xem danh sách phản hồi
                    </a>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted">Bạn chưa được phân công hoặc chưa có khảo sát nào.</p>
        </div>
    }
</div>
