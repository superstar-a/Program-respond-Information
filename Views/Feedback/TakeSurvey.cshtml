@model QLTTYKPH.ViewModels.SurveySubmitViewModel
@{
    ViewData["Title"] = "Thực hiện khảo sát";
}

@section Styles {
    <link href="~/css/google-forms.css" rel="stylesheet" asp-append-version="true" />
}

<div class="gg-main-content">
    <div class="gg-form-container">
        
        <form asp-action="TakeSurvey" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SurveyId" />
            <input type="hidden" asp-for="SurveyTitle" />
            <input type="hidden" asp-for="SurveyDescription" />

            <div class="gg-card gg-card-header-top">
                <div class="gg-card-body">
                    <h1 class="gg-title">@Model.SurveyTitle</h1>
                    @if (!string.IsNullOrEmpty(Model.SurveyDescription))
                    {
                        <p class="gg-desc">@Model.SurveyDescription</p>
                    }
                    <div class="mt-3 small text-danger">* Bắt buộc</div>
                </div>
            </div>

            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                var q = Model.Questions[i];
                <input type="hidden" name="Questions[@i].QuestionId" value="@q.QuestionId" />
                <input type="hidden" name="Questions[@i].Text" value="@q.Text" />
                <input type="hidden" name="Questions[@i].Type" value="@((int)q.Type)" />
                @for (int j = 0; j < q.OptionList.Count; j++)
                {
                    <input type="hidden" name="Questions[@i].OptionList[@j]" value="@q.OptionList[j]" />
                }

                <div class="gg-card">
                    <div class="gg-card-body">
                        <div class="gg-question-title">
                            <span>@q.Text <span class="text-danger">*</span></span>
                        </div>

                        @if (q.Type == QLTTYKPH.Models.QuestionType.Text)
                        {
                            <input type="text" name="Questions[@i].AnswerText" class="gg-input-text" 
                                   placeholder="Câu trả lời của bạn" required />
                        }
                        else if (q.Type == QLTTYKPH.Models.QuestionType.SingleChoice)
                        {
                            <div class="mt-2">
                                @foreach (var opt in q.OptionList)
                                {
                                    <div class="gg-option-row">
                                        <input class="form-check-input" type="radio" required
                                               name="Questions[@i].AnswerText" value="@opt" id="q@(i)_@opt" />
                                        <label class="form-check-label" for="q@(i)_@opt">@opt</label>
                                    </div>
                                }
                            </div>
                        }
                        else if (q.Type == QLTTYKPH.Models.QuestionType.MultipleChoice)
                        {
                            <div class="mt-2">
                                @for (int k = 0; k < q.OptionList.Count; k++)
                                {
                                    var opt = q.OptionList[k];
                                    <div class="gg-option-row">
                                        <!-- Note: For MultipleChoice, HTML validation 'required' on checkboxes is tricky, we can omit it or handle via JS -->
                                        <input class="form-check-input" type="checkbox"
                                               name="Questions[@i].SelectedOptions" value="@opt" id="q@(i)_@k" />
                                        <label class="form-check-label" for="q@(i)_@k">@opt</label>
                                    </div>
                                }
                            </div>
                        }
                        else if (q.Type == QLTTYKPH.Models.QuestionType.Rating)
                        {
                            <div class="gg-rating-scale">
                                @for (int r = 1; r <= 5; r++)
                                {
                                    <div class="gg-rating-option">
                                        <label for="q@(i)_r@r" class="form-check-label mb-2">@r</label>
                                        <input class="form-check-input" type="radio" required
                                               name="Questions[@i].AnswerText" value="@r" id="q@(i)_r@r" />
                                    </div>
                                }
                            </div>
                            <div class="d-flex justify-content-between px-3 text-muted small mt-2">
                                <span>Rất kém</span>
                                <span>Rất tốt</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mt-4 mb-5">
                <button type="submit" class="gg-btn-primary" 
                        onclick="return confirm('Bạn đã chắc chắn muốn gửi phản hồi? Bạn sẽ không thể sửa sau khi gửi.')">
                    Gửi phản hồi
                </button>
                <a asp-action="OpenSurveys" class="gg-btn-clear text-decoration-none">
                    Xóa hết câu trả lời
                </a>
            </div>
        </form>
        
    </div>
</div>
