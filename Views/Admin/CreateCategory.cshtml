@model QLTTYKPH.Models.Category
@{
    ViewData["Title"] = "Thêm danh mục";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-primary text-white"><i class="bi bi-tag me-2"></i>Thêm danh mục mới</div>
            <div class="card-body p-4">
                <form asp-action="CreateCategory" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Tên danh mục..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Tạo</button>
                        <a asp-action="Categories" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
