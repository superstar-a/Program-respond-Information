@model IEnumerable<QLTTYKPH.Models.Class>
@{
    ViewData["Title"] = "Quản lý lớp";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-book me-2 text-primary"></i>Quản lý lớp</h5>
    <a asp-action="CreateClass" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Thêm lớp mới
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Tên lớp</th>
                        <th>Mô tả</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{int stt = 1;}
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-muted small">@(stt++)</td>
                            <td><strong>@c.Name</strong></td>
                            <td class="small text-muted">@(c.Description ?? "-")</td>
                            <td class="text-center">
                                <a asp-action="EditClass" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="DeleteClass" asp-route-id="@c.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xác nhận xóa lớp @c.Name?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có lớp nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
