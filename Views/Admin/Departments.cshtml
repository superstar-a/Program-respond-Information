@model IEnumerable<QLTTYKPH.Models.Department>
@{
    ViewData["Title"] = "Quản lý phòng ban";
}
<div class="row">
    <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-building me-2 text-primary"></i>Phòng ban</h5>
            <a asp-action="CreateDepartment" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i>Thêm phòng ban
            </a>
        </div>
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>#</th><th>Tên phòng ban</th><th class="text-center">Thao tác</th></tr>
                    </thead>
                    <tbody>
                        @{int stt = 1;}
                        @foreach (var d in Model)
                        {
                            <tr>
                                <td class="text-muted small">@stt++</td>
                                <td><i class="bi bi-building me-2 text-secondary"></i>@d.Name</td>
                                <td class="text-center">
                                    <a asp-action="EditDepartment" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="DeleteDepartment" asp-route-id="@d.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Xóa phòng ban @d.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-3">Chưa có phòng ban nào</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
