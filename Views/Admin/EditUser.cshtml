@model QLTTYKPH.Models.User
@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa tài khoản: <strong>@Model.Username</strong>
            </div>
            <div class="card-body p-4">
                <form asp-action="EditUser" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên đăng nhập</label>
                        <input type="text" class="form-control" value="@Model.Username" disabled />
                    </div>
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select">
                            <option value="0">Quản trị viên</option>
                            <option value="1">Nhân viên</option>
                            <option value="2">Sinh viên</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ClassId" class="form-label fw-semibold"></label>
                        <select asp-for="ClassId" class="form-select">
                            <option value="">-- Chọn lớp --</option>
                            @foreach (var c in (List<QLTTYKPH.Models.Class>)ViewBag.Classes)
                            {
                                <option value="@c.Id" selected="@(Model.ClassId == c.Id)">@c.Name</option>
                            }
                        </select>
                        <div class="form-text">Chỉ dành cho sinh viên</div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Department" class="form-label fw-semibold"></label>
                        <select asp-for="Department" class="form-select">
                            <option value="">-- Chọn phòng ban --</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var d in (List<QLTTYKPH.Models.Department>)ViewBag.Departments)
                                {
                                    <option value="@d.Name">@d.Name</option>
                                }
                            }
                        </select>
                        <div class="form-text">Chỉ dành cho nhân viên</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu mới <span class="text-muted fw-normal small">(để trống nếu không đổi)</span></label>
                        <input type="password" name="newPassword" class="form-control" placeholder="Nhập mật khẩu mới..." />
                    </div>
                    <div class="mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="mustChangePassword" id="mustChangePassword" @(Model.MustChangePassword ? "checked" : "")>
                            <label class="form-check-label fw-semibold" for="mustChangePassword">
                                Yêu cầu đổi mật khẩu khi đăng nhập lần sau
                            </label>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-dark">
                            <i class="bi bi-check-circle me-1"></i>Lưu thay đổi
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $(document).ready(function () {
            function toggleFields() {
                var role = $('#Role').val();
                if (role == '0') { // Admin
                    $('#ClassId').prop('disabled', true).val('');
                    $('#Department').prop('disabled', true).val('');
                } else if (role == '1') { // Staff
                    $('#ClassId').prop('disabled', true).val('');
                    $('#Department').prop('disabled', false);
                } else if (role == '2') { // Student
                    $('#ClassId').prop('disabled', false);
                    $('#Department').prop('disabled', true).val('');
                }
            }

            $('#Role').change(toggleFields);
            toggleFields(); // Call on load
        });
    </script>
}
