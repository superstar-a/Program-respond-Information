@model QLTTYKPH.Models.User
@{
    ViewData["Title"] = "Thêm tài khoản";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-person-plus me-2"></i>Thêm tài khoản mới
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateUser" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold"></label>
                        <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select">
                            <option value="0">Quản trị viên</option>
                            <option value="1">Nhân viên</option>
                            <option value="2">Sinh viên</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ClassId" class="form-label fw-semibold"></label>
                        <select asp-for="ClassId" class="form-select">
                            <option value="">-- Chọn lớp --</option>
                            @foreach (var c in (List<QLTTYKPH.Models.Class>)ViewBag.Classes)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <div class="form-text">Chỉ dành cho sinh viên</div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Department" class="form-label fw-semibold"></label>
                        <input asp-for="Department" class="form-control" placeholder="Phòng ban (dành cho nhân viên)" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Tạo tài khoản
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
