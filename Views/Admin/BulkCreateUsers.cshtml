@{
    ViewData["Title"] = "Tạo tài khoản hàng loạt";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-people-fill me-2"></i>Tạo tài khoản hàng loạt
            </div>
            <div class="card-body p-4">
                <form asp-action="BulkCreateUsers" method="post">
                    @Html.AntiForgeryToken()
                    <div class="alert alert-info small">
                        <strong>Định dạng:</strong> username,fullname,password (mỗi dòng một tài khoản)<br>
                        <strong>Ví dụ:</strong><br>
                        sv001,Nguyễn Văn A,123456<br>
                        sv002,Trần Thị B,123456
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Vai trò mặc định</label>
                            <select name="defaultRole" class="form-select">
                                <option value="2">Sinh viên</option>
                                <option value="1">Nhân viên</option>
                                <option value="0">Quản trị viên</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Lớp mặc định</label>
                            <select name="defaultClassId" class="form-select">
                                <option value="">-- Không chọn --</option>
                                @foreach (var c in (List<QLTTYKPH.Models.Class>)ViewBag.Classes)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Dữ liệu CSV</label>
                        <textarea name="csvData" class="form-control font-monospace" rows="10" placeholder="username,fullname,password"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Tạo tài khoản
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
