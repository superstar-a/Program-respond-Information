@model QLTTYKPH.Models.Department
@{
    ViewData["Title"] = "Sửa phòng ban";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-warning text-dark"><i class="bi bi-pencil me-2"></i>Sửa phòng ban</div>
            <div class="card-body p-4">
                <form asp-action="EditDepartment" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-check-circle me-1"></i>Lưu</button>
                        <a asp-action="Departments" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
