@model QLTTYKPH.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - QLTTYKPH</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: url('/img/anh-nen.png') no-repeat center center fixed; background-size: cover; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; }
        .login-card { background: rgba(255, 255, 255, 0.95); border-radius: 16px; padding: 40px; width: 100%; max-width: 420px; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
        .login-title { text-align: center; color: #1a2942; font-weight: 700; font-size: 1.4rem; }
        .login-subtitle { text-align: center; color: #6c757d; font-size: .88rem; margin-bottom: 28px; }
        .form-control { border-radius: 8px; padding: 10px 14px; border-color: #dee2e6; }
        .form-control:focus { box-shadow: 0 0 0 3px rgba(26,95,158,.15); border-color: #1a5f9e; }
        .btn-login { background: linear-gradient(135deg, #1a5f9e, #4db6f5); border: none; border-radius: 8px; padding: 11px; font-weight: 600; letter-spacing: .5px; width: 100%; color: #fff; }
        .btn-login:hover { opacity: .9; color: #fff; }
        .input-group-text { border-radius: 8px 0 0 8px; background: #f8f9fa; }
        label { color: #495057; font-weight: 500; font-size: .9rem; }
    </style>
</head>
<body>
<div class="login-card">
    <img src="~/img/logo.png" alt="Logo" style="width: 80px; display: block; margin: 0 auto 20px;" />
    <h4 class="login-title">QLTTYKPH</h4>
    <p class="login-subtitle">Quản lý Tiếp nhận & Xử lý Ý kiến Phản hồi</p>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="mb-3">
            <label asp-for="Username" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" autocomplete="username" />
            </div>
            <span asp-validation-for="Username" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Password" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" autocomplete="current-password" />
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-login">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
        </button>
    </form>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
