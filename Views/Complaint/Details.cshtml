@model QLTTYKPH.Models.Complaint
@{
    var role = Context.Session.GetString("UserRole");
    ViewData["Title"] = "Chi tiết khiếu nại";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
    </a>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-text me-2"></i>Nội dung khiếu nại</span>
                <span class="badge @(Model.Status == QLTTYKPH.Models.ComplaintStatus.New ? "bg-danger" : Model.Status == QLTTYKPH.Models.ComplaintStatus.Processing ? "bg-warning text-dark" : "bg-success")">
                    @switch (Model.Status)
                    {
                        case QLTTYKPH.Models.ComplaintStatus.New:
                            @:Mới
                            break;
                        case QLTTYKPH.Models.ComplaintStatus.Processing:
                            @:Đang xử lý
                            break;
                        case QLTTYKPH.Models.ComplaintStatus.Resolved:
                            @:Đã giải quyết
                            break;
                    }
                </span>
            </div>
            <div class="card-body p-4">
                <h4 class="fw-bold mb-3 text-dark">@Model.Title</h4>
                <hr />
                <div class="mb-4 text-secondary" style="white-space: pre-line; line-height: 1.6;">
                    @Model.Content
                </div>
                
                @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                {
                    <div class="mb-4">
                        <p class="fw-semibold mb-2"><i class="bi bi-paperclip me-1"></i>Tệp đính kèm / Minh chứng:</p>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var path in Model.AttachmentPath.Split(';', StringSplitOptions.RemoveEmptyEntries))
                            {
                                var ext = System.IO.Path.GetExtension(path).ToLower();
                                if (ext == ".jpg" || ext == ".jpeg" || ext == ".png")
                                {
                                    <div class="mb-2">
                                        <a href="@path" target="_blank">
                                            <img src="@path" alt="Ảnh minh chứng" class="img-fluid rounded border" style="max-height: 200px;" />
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <div>
                                        <a href="@path" download class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-download me-1"></i>Tải @System.IO.Path.GetFileName(path)
                                        </a>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                <hr />
                <div class="row g-2 text-muted small">
                    <div class="col-sm-6">
                        <i class="bi bi-calendar-event me-1"></i>Thời gian gửi: <strong>@Model.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    <div class="col-sm-6 text-sm-end">
                        <i class="bi bi-building me-1"></i>Gửi tới: <strong>@Model.Department?.Name</strong>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ResolutionNote))
        {
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-reply-fill me-2"></i>Thông tin phản hồi từ phòng ban
                </div>
                <div class="card-body p-4">
                    <div class="text-dark mb-3" style="white-space: pre-line; line-height: 1.6;">
                        @Model.ResolutionNote
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.ResolutionAttachmentPath))
                    {
                        <div class="mb-3">
                            <p class="fw-semibold mb-2"><i class="bi bi-paperclip me-1"></i>Tệp minh chứng giải quyết:</p>
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var path in Model.ResolutionAttachmentPath.Split(';', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    var resExt = System.IO.Path.GetExtension(path).ToLower();
                                    if (resExt == ".jpg" || resExt == ".jpeg" || resExt == ".png")
                                    {
                                        <div class="mb-2">
                                            <a href="@path" target="_blank">
                                                <img src="@path" alt="Ảnh giải quyết" class="img-fluid rounded border" style="max-height: 200px;" />
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div>
                                            <a href="@path" download class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-download me-1"></i>Tải @System.IO.Path.GetFileName(path)
                                            </a>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }

                    <hr />
                    <div class="row g-2 text-muted small">
                        <div class="col-sm-6">
                            <i class="bi bi-person-fill me-1"></i>Người phản hồi: <strong>@(Model.ResolvedByUser?.FullName ?? "Cán bộ phòng ban")</strong>
                        </div>
                        @if (Model.ResolvedAt.HasValue)
                        {
                            <div class="col-sm-6 text-sm-end">
                                <i class="bi bi-clock-fill me-1"></i>Thời gian: <strong>@Model.ResolvedAt.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-info-circle me-2"></i>Thông tin liên quan
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush mb-0">
                    @if (Model.IsAnonymous && role != "Student")
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted">Học sinh khiếu nại</span>
                            <span class="badge bg-secondary"><i class="bi bi-incognito me-1"></i>Ẩn danh</span>
                        </li>
                    }
                    else
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted">Học sinh khiếu nại</span>
                            <strong>@Model.User?.FullName</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted">Mã sinh viên</span>
                            <strong>@Model.User?.Username</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted">Lớp</span>
                            <strong>@(Model.User?.Class?.Name ?? "-")</strong>
                        </li>
                    }
                </ul>
            </div>
        </div>

        @if (role == "Admin" || role == "Staff")
        {
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-check2-square me-2"></i>Cập nhật tiến trình & Giải quyết
                </div>
                <div class="card-body p-4">
                    <form asp-action="Process" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nội dung phản hồi / Giải quyết</label>
                            <textarea name="resolutionNote" rows="5" class="form-control" placeholder="Nhập câu trả lời, hướng giải quyết khiếu nại... (Bắt buộc)">@Model.ResolutionNote</textarea>
                        </div>

                        <div class="mb-3">
                            <label for="attachments" class="form-label fw-semibold">Tải lên tệp minh chứng (Ảnh, PDF, Word, Excel - Tối đa 5MB)</label>
                            <input type="file" name="attachments" id="attachments" class="form-control" accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx" multiple onchange="previewImages(this, 'imagePreviewContainer')" />
                            <div id="imagePreviewContainer" class="d-flex flex-wrap gap-3 mt-3"></div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Cập nhật trạng thái</label>
                            <select name="newStatus" class="form-select">
                                <option value="Processing" selected="@(Model.Status == QLTTYKPH.Models.ComplaintStatus.Processing)">Đang xử lý</option>
                                <option value="Resolved" selected="@(Model.Status == QLTTYKPH.Models.ComplaintStatus.Resolved)">Đã giải quyết (Hoàn thành)</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-arrow-right-circle me-1"></i>Lưu phản hồi & Cập nhật
                        </button>
                    </form>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        function previewImages(input, containerId) {
            const container = document.getElementById(containerId);
            if (!container) return;
            container.innerHTML = ''; 
            const files = input.files;
            if (!files) return;
            
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                if (file.type.match('image.*')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'img-fluid rounded border shadow-sm';
                        img.style.maxHeight = '400px'; 
                        container.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                } else {
                    const span = document.createElement('span');
                    span.className = 'badge bg-secondary p-2';
                    span.textContent = 'Đã chọn tệp: ' + file.name;
                    container.appendChild(span);
                }
            }
        }
    </script>
}
