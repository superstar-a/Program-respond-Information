@model QLTTYKPH.Models.Complaint
@{
    ViewData["Title"] = "Gửi khiếu nại mới";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-send-fill me-2"></i>Gửi khiếu nại mới
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Tiêu đề khiếu nại</label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tóm tắt tiêu đề khiếu nại" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DepartmentId" class="form-label fw-semibold">Phòng ban tiếp nhận</label>
                        <select asp-for="DepartmentId" class="form-select">
                            <option value="">-- Chọn phòng ban giải quyết khiếu nại --</option>
                            @foreach (var d in (List<QLTTYKPH.Models.Department>)ViewBag.Departments)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        <div class="form-text">Khiếu nại của bạn sẽ được gửi trực tiếp đến cán bộ phụ trách phòng ban này.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-semibold">Nội dung chi tiết</label>
                        <textarea asp-for="Content" class="form-control" rows="5" placeholder="Mô tả chi tiết vấn đề bạn đang gặp phải..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label for="attachments" class="form-label fw-semibold">Tệp đính kèm / Ảnh minh chứng (Tối đa 5MB)</label>
                        <input type="file" name="attachments" id="attachments" class="form-control" accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx" multiple onchange="previewImages(this, 'imagePreviewContainer')" />
                        <div id="imagePreviewContainer" class="d-flex flex-wrap gap-3 mt-3"></div>
                        <div class="form-text mt-2">Bạn có thể tải lên ảnh chụp màn hình hoặc tài liệu để làm bằng chứng.</div>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="IsAnonymous" class="form-check-input" />
                        <label asp-for="IsAnonymous" class="form-check-label fw-semibold text-danger">Gửi ẩn danh</label>
                        <div class="form-text">Khi chọn ẩn danh, người tiếp nhận (Admin/Phòng ban) sẽ không thể thấy tên và lớp của bạn.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Gửi khiếu nại
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImages(input, containerId) {
            const container = document.getElementById(containerId);
            if (!container) return;
            container.innerHTML = ''; 
            const files = input.files;
            if (!files) return;
            
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                if (file.type.match('image.*')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'img-fluid rounded border shadow-sm';
                        img.style.maxHeight = '400px'; 
                        container.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                } else {
                    const span = document.createElement('span');
                    span.className = 'badge bg-secondary p-2';
                    span.textContent = 'Đã chọn tệp: ' + file.name;
                    container.appendChild(span);
                }
            }
        }
    </script>
}
